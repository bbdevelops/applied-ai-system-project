# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# Google Gemini API key — required for the --rag flag (RAG-enriched explanations).
# Without this, --rag falls back to deterministic explanations with a warning.
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
